<div class="row align-items-center mb-1">
  <div class="col">
    <h1>Places</h1>
  </div>
</div>

<div class="mt-2 mb-5">
  <a href="/places/new" class = "mt-4 btn btn-primary">New Place</a>
</div>

<ul class="list-group list-group-flush mb-4">
  <% for place in @places %>
    <li class="list-group-item d-flex align-items-center mb-0 border-0 ps-0">
      <span class="fs-5 me-2">🌎</span>
      <a href="/places/<%= place["id"] %>" class="fw-normal fs-5"><%= place["name"] %></a>
    </li>
  <% end %>
</ul>