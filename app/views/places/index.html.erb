<div class="row align-items-center mb-4">
  <div class="col">
    <h1>Places</h1>
  </div>
</div>

<div class="mb-4">
  <a href="/places/new" class = "btn btn-primary">New Place</a>
</div>

<div class="row">
  <% if @places.empty? %>
    <div class="col-12">
      <div class="alert alert-primary">
        No places yet. Start by clicking "New Place"!
      </div>
    </div>
  <% else %>
    <div class="col-12">
      <ul class="list-group list-group-flush mb-4">
        <% for place in @places %>
          <li class="list-group-item d-flex align-items-center mb-0 border-0 ps-0">
            <a href="/places/<%= place["id"] %>" class="fw-normal fs-5">
              <i class="bi bi-geo-alt-fill me-1"></i><%= place["name"] %>
            </a>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>